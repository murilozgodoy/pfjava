    "description": "Coleção Postman para testar a API REST de usuários e cursos.\n\nAntes de testar rotas POST, PUT e DELETE, rode a aplicação e crie o ADMIN no H2 Console:\nINSERT INTO users (nome, cpf, papel) VALUES ('Admin', '12345678900', 'ADMIN');\n\nDepois disso, use X-USER-ID = 1 para rotas protegidas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "2"
    },
    {
      "key": "cursoId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET Listar usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          }
        },
        {
          "name": "GET Buscar usuario por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "POST Criar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('userId', json.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-USER-ID",
                "value": "{{adminId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nome\": \"Murilo\",\n    \"cpf\": \"11122233344\",\n    \"papel\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          }
        },
        {
          "name": "PUT Atualizar usuario",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-USER-ID",
                "value": "{{adminId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nome\": \"Murilo Atualizado\",\n    \"cpf\": \"11122233344\",\n    \"papel\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "DELETE Deletar usuario",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-USER-ID",
                "value": "{{adminId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Use depois de remover o usuario dos cursos, para evitar conflito de relacionamento."
          }
        }
      ]
